# Required: Solana RPC endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com

# Required: Path to watcher bot keypair
WATCHER_KEYPAIR_PATH=./watcher-keypair.json

# Required: Anderdzi program ID
PROGRAM_ID=6xgUzv1pYovTNK1QYAEK5xRdHeTwaum6rGX6AEJqhA1x

# Optional: Telegram Bot API token (enables notification sending)
TELEGRAM_BOT_TOKEN=

# Optional: API server port (default: 3001)
API_PORT=3001

# Optional: SQLite database path (default: bot.db)
DATABASE_PATH=bot.db
